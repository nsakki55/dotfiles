// Place your key bindings in this file to override the defaults
[
    // エクスプローラー
    {
        "key": "j",
        "command": "list.focusDown",
        "when": "listFocus && !inputFocus"
    },
    {
        "key": "k",
        "command": "list.focusUp",
        "when": "listFocus && !inputFocus"
    },
    {
        "key": "h",
        "command": "list.collapse",
        "when": "listFocus && !inputFocus"
    },
    {
        "key": "l",
        "command": "list.select",
        "when": "listFocus && !inputFocus"
    },
    {
        "key": "d",
        "command": "deleteFile",
        "when": "explorerViewletFocus && filesExplorerFocus && !inputFocus"
    },
    {
        "key": "y",
        "command": "filesExplorer.copy",
        "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        "key": "p",
        "command": "filesExplorer.paste",
        "when": "explorerViewletVisible && filesExplorerFocus && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        "key": "cmd+n",
        "command": "explorer.newFile"
    },
    {
        "key": "ctrl+shift+n",
        "command": "explorer.newFolder"
    },
    {
        "key": "ctrl+e",
        "command": "workbench.view.explorer",
        "when": "!sideBarVisible"
    },
    {
        "key": "ctrl+e",
        "command": "workbench.action.toggleSidebarVisibility",
        "when": "sideBarVisible"
    },
    // 開いているエディタ一覧
    {
        "key": "ctrl+o",
        "command": "workbench.files.action.focusOpenEditorsView",
        "when": "!openEditorsFocus"
    },
    {
        "key": "ctrl+o",
        "command": "workbench.action.toggleSidebarVisibility",
        "when": "openEditorsFocus"
    },
    // ターミナル
    {
        "key": "ctrl+w k",
        "command": "workbench.action.focusFirstEditorGroup",
        "when": "terminalFocus"
    },
    {
        "key": "cmd+1",
        "command": "workbench.action.focusFirstEditorGroup"
    },
    {
        "key": "cmd+1",
        "command": "-workbench.action.focusFirstEditorGroup"
    },
    // エラー部分への移動
    // https://1-notes.com/visual-studio-code-shortcut-key-move-to-the-problem-area/
    {
        "key": "cmd+e",
        "command": "editor.action.marker.nextInFiles",
        "when": "editorFocus"
    },
    {
        "key": "cmd+E",
        "command": "editor.action.marker.prevInFiles",
        "when": "editorFocus"
    },
    // ターミナル切り替え
    {
        "key": "ctrl+k",
        "command": "workbench.action.terminal.toggleTerminal",
        "when": "!terminalFocus && vim.mode != 'SearchInProgressMode'"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.terminal.toggleTerminal",
        "when": "terminalFocus && vim.mode != 'SearchInProgressMode'"
    },
    {
        "key": "ctrl+g g",
        "command": "lazygit.openLazygit",
    },
    {
        "key": "alt+/",
        "command": "editor.action.triggerSuggest",
        "when": "editorHasCompletionItemProvider && textInputFocus && !editorReadonly && !suggestWidgetVisible && vim.mode == 'Insert'"
    },
    // サイドバーとエディタ間のフォーカス移動
    {
        "key": "ctrl+l",
        "command": "workbench.action.focusSideBar",
        "when": "sideBarVisible && editorFocus"
    },
    {
        "key": "ctrl+h",
        "command": "workbench.action.focusFirstEditorGroup",
        "when": "sideBarVisible && sideBarFocus"
    },
    // エディタを横に分割
    {
        "key": "cmd+shift+\\",
        "command": "workbench.action.splitEditorDown"
    },
    //  Search Editorの変更を保存
    // https://marketplace.visualstudio.com/items?itemName=jakearl.search-editor-apply-changes
    {
        "key": "cmd+s",
        "command": "searchEditorApplyChanges.apply",
        "when": "inSearchEditor"
    },
    // 前の場所に戻る（ナビゲーション）
    {
        "key": "ctrl+t",
        "command": "workbench.action.navigateBack"
    },
    // エディタグループの幅を変更
    {
        "key": "ctrl+w >",
        "command": "workbench.action.increaseViewWidth"
    },
    {
        "key": "ctrl+w <",
        "command": "workbench.action.decreaseViewWidth"
    },
    // コマンドパレットでのVimキーバインド
    {
        "key": "ctrl+j",
        "command": "workbench.action.quickOpenSelectNext",
        "when": "inQuickOpen"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.quickOpenSelectPrevious",
        "when": "inQuickOpen"
    },
    {
        "key": "ctrl+l",
        "command": "workbench.action.acceptSelectedQuickOpenItem",
        "when": "inQuickOpen"
    },
]


